{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "target": "es2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    /* Interoperability (SANGAT PENTING) */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    /* Typechecking Options */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,

    /* Outputs */
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
