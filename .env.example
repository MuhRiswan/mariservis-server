# ============================================
# MARI SERVIS - SERVER ENVIRONMENT CONFIGURATION
# ============================================

# Database
DATABASE_URL="postgresql://admin:adminpassword@localhost:5433/mariservis_db?schema=public"

# Server
PORT=5000
NODE_ENV="development"  # development | production | test

# Authentication
JWT_SECRET="GANTI_INI_DENGAN_SECRET_KUAT_UNIK"  # Minimal 32 karakter
JWT_EXPIRES_IN="7d"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN="http://localhost:3000"  # Arahkan ke domain produksi nanti
CORS_CREDENTIALS="true"

# Security Headers
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline';"

# Logging
LOG_LEVEL="info"  # error | warn | info | debug

# Email Service (Jika ada fitur reminder WA)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-password"

# Payment Gateway (Jika ada fitur kasir)
# PAYMENT_GATEWAY_ID=""
# PAYMENT_GATEWAY_SECRET=""

# API Keys
# OPENAI_API_KEY=""
# WHATSAPP_API_KEY=""
